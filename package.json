{
  "name": "emulator-studio",
  "version": "1.0.0",
  "private": true,
  "description": "EMulator Studio — universal Android/iOS/PWA device test lab. Connect any repo, test any .apk / iOS build / PWA in real device frames, capture console & network errors, screenshot, export a Markdown report, and push it back to the repo.",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "html2canvas": "^1.4.1",
    "jszip": "^3.10.1",
    "next": "14.2.32",
    "playwright-core": "^1.49.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/node": "^20.17.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.32",
    "typescript": "^5.6.3"
  }
}
